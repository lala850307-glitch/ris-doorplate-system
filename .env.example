# ── 資料庫設定 ───────────────────────────────────────────────
# DB_HOST：Docker 環境填 "postgres"（service 名稱）
#           本機直接執行填 "localhost"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crawldb
DB_USER=layla
DB_PASSWORD=123456

# ── 爬蟲設定 ─────────────────────────────────────────────────
# HEADLESS=true  → 無視窗模式（Docker / CI 環境）
# HEADLESS=false → 有視窗模式（本機執行，可觀察驗證碼填入過程）
HEADLESS=false

# ── Email 異常通知（可選）────────────────────────────────────
# 使用 Gmail：需先至 https://myaccount.google.com/apppasswords 產生 App Password
# 三個欄位留空程式仍可正常執行，只會印 WARNING log
# 請填入自己的 Gmail 帳號與 App Password 進行測試
MAIL_USER=
MAIL_PASSWORD=
MAIL_TO=

