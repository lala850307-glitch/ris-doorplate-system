{
  "annotations": { "list": [] },
  "description": "爬蟲與 API 即時 Log 監控",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "🚨 ERROR 次數（爬蟲+API）",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({container_name=~\"api|crawler\"} |= \"ERROR\" [$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "⚠️ WARNING 次數（爬蟲+API）",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "orange", "value": 10 }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({container_name=~\"api|crawler\"} |= \"WARNING\" [$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "✅ 爬蟲成功區數",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 6 },
            { "color": "green", "value": 11 }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({container_name=\"crawler\"} |= \"完成，爬取\" [$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "📡 API 查詢次數",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({container_name=\"api\"} |= \"查詢完成\" [$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "📈 爬蟲+API Log 量（每分鐘）",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "crawler" }, "properties": [{ "id": "color", "value": { "fixedColor": "#16a34a", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "api" },     "properties": [{ "id": "color", "value": { "fixedColor": "#2563eb", "mode": "fixed" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum by (container_name) (count_over_time({container_name=~\"api|crawler\"}[1m]))",
        "legendFormat": "{{container_name}}",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "🕷 爬蟲 Log（crawler）",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "{container_name=\"crawler\"}",
        "refId": "A"
      }]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "🚀 API Log（api）",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "{container_name=\"api\"}",
        "refId": "A"
      }]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "🚨 ERROR / WARNING Log（爬蟲+API）",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 25 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "{container_name=~\"api|crawler\"} |~ \"ERROR|WARNING|CRITICAL\"",
        "refId": "A"
      }]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["crawler", "api", "loki"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "🏨 門牌爬蟲監控儀表板",
  "uid": "cathay-crawler-monitor",
  "version": 4
}
